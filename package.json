{
  "name": "flexweg-cms",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Static WordPress-like CMS that publishes pages to Flexweg via API. Admin SPA built with React + TypeScript + Firebase.",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "themes:tailwind": "node scripts/build-theme-tailwind.mjs",
    "predev": "npm run themes:tailwind",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prebuild": "npm run typecheck && npm run themes:tailwind",
    "build": "vite build && node scripts/build-themes.mjs && node scripts/build-bundled-externals.mjs && node scripts/pack-bundled-zips.mjs",
    "pack:zips": "node scripts/pack-bundled-zips.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@types/jszip": "^3.4.1",
    "@types/turndown": "^5.0.6",
    "@uiw/react-codemirror": "^4.25.9",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.3",
    "firebase": "^11.0.2",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "marked": "^15.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-router-dom": "^6.28.0",
    "tiptap-markdown": "^0.8.10",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "sass": "^1.83.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^6.0.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
