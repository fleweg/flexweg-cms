coverage
# Generated by scripts/build-theme-tailwind.mjs from each theme's theme.css
src/themes/*/theme.compiled.css
demo-content/flexweg-cms-docs/*
demo-content/marketplace-core/*

# `dist/` IS committed — used to host install links to the bundled
# plugin / theme ZIPs (`dist/packs/{plugins,themes}/<id>.zip`) that
# admins drag onto the Plugins / Themes install dropzone. Refreshed
# by `npm run build`.
#
# Two paths inside dist/ that we DO want to ignore:
#   - dist/.DS_Store — macOS Finder droppings (covered by the
#     repo-wide `.DS_Store` rule above)
#   - any local credential leak via dist/admin/config.js if a developer
#     builds with `.env` filled in. The shipped `public/config.js` and
#     freshly-built `dist/admin/config.js` both ship as
#     `window.__FLEXWEG_CONFIG__ = null;` stubs — confirm with
#     `grep null dist/admin/config.js` before committing.
