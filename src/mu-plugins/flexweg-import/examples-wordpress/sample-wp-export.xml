<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sample WordPress eXtended RSS (WXR) export for testing flexweg-import.
  Hand-crafted to exercise:
   - posts + pages + attachments
   - hierarchical categories (News > Tech, News > Sports)
   - tags
   - multi-category post (demotion warning)
   - statuses: publish, draft, pending (→ draft + warning)
   - _thumbnail_id (hero image resolution)
   - inline <img> in content (image rewrite at import)
   - dc:creator (author resolution)
   - <link> (legacyUrl preservation)

  Image URLs use picsum.photos so the import can actually fetch them.
  If your network blocks the host, the posts still get created but
  without hero images (warning in the dry-run / activity log).
-->
<rss version="2.0"
     xmlns:wp="http://wordpress.org/export/1.2/"
     xmlns:content="http://purl.org/rss/1.0/modules/content/"
     xmlns:excerpt="http://wordpress.org/export/1.2/excerpt/"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>Sample WordPress site</title>
    <link>https://old.example.com</link>
    <description>Hand-crafted fixture for the flexweg-import plugin.</description>
    <language>en-US</language>

    <!--
      Channel-level taxonomy. The parser uses `<wp:category_parent>`
      (a slug, not an id) to build hierarchies. News is top-level;
      Tech and Sports declare News as their parent.
    -->
    <wp:category>
      <wp:term_id>1</wp:term_id>
      <wp:category_nicename>news</wp:category_nicename>
      <wp:cat_name><![CDATA[News]]></wp:cat_name>
      <wp:category_parent></wp:category_parent>
    </wp:category>
    <wp:category>
      <wp:term_id>2</wp:term_id>
      <wp:category_nicename>tech</wp:category_nicename>
      <wp:cat_name><![CDATA[Tech]]></wp:cat_name>
      <wp:category_parent>news</wp:category_parent>
    </wp:category>
    <wp:category>
      <wp:term_id>3</wp:term_id>
      <wp:category_nicename>sports</wp:category_nicename>
      <wp:cat_name><![CDATA[Sports]]></wp:cat_name>
      <wp:category_parent>news</wp:category_parent>
    </wp:category>
    <wp:category>
      <wp:term_id>4</wp:term_id>
      <wp:category_nicename>recipes</wp:category_nicename>
      <wp:cat_name><![CDATA[Recipes]]></wp:cat_name>
      <wp:category_parent></wp:category_parent>
    </wp:category>

    <wp:tag>
      <wp:term_id>10</wp:term_id>
      <wp:tag_slug>migration</wp:tag_slug>
      <wp:tag_name><![CDATA[migration]]></wp:tag_name>
    </wp:tag>
    <wp:tag>
      <wp:term_id>11</wp:term_id>
      <wp:tag_slug>2026</wp:tag_slug>
      <wp:tag_name><![CDATA[2026]]></wp:tag_name>
    </wp:tag>
    <wp:tag>
